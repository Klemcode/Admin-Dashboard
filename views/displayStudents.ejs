<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Students</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background: #f8f9fa;
        }

        .page-title{
            font-weight: 700;
            color: #0d6efd;
        }

        .student-card{
            border: none;
            border-radius: 15px;
            transition: 0.3s ease;
        }

        .student-card:hover{
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

        .student-number{
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: #0d6efd;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }
    </style>
</head>

<body>

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="page-title">Students Data</h1>
        <p class="text-muted">Manage all registered students</p>
    </div>

    <% student.forEach((_, idx) => { %>

        <div class="card student-card shadow-sm mb-4">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <div class="d-flex align-items-center gap-3">
                        <div class="student-number">
                            <%= idx + 1 %>
                        </div>

                        <div>
                            <h5 class="mb-1 fw-bold"><%= _.name %></h5>
                            <p class="mb-0 text-muted"><%= _.degree %></p>
                            <p class="mb-1 fw-bold"><%= _.email %></p>
                            <p class="mb-1 fw-bold"><%= _.cgpa %></p>

                        </div>
                    </div>


                     <div class="card mb-4 shadow-sm p-3">


      <img 
        src="<%= _.image %>" 
        class="img-fluid rounded"
        style="width:180px; height:180px; object-fit:cover;"
      >

  </div>


                    <div class="d-flex gap-2">
                        <button class="btn btn-warning btn-sm px-4">
                            Edit
                        </button>

                        <button class="btn btn-danger btn-sm px-4">
                            Delete
                        </button>
                    </div>

                </div>

            </div>
        </div>

    <% }) %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>